{
  "name": "human-replay",
  "displayName": "Human Replay",
  "description": "Replay sandboxed AI work into your real branch one Tab at a time. Guide-driven, model-free replay; local FIM autocomplete on the side.",
  "version": "0.0.1",
  "publisher": "utilitydelta",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "keywords": [
    "ai",
    "replay",
    "code review",
    "tree-sitter",
    "autocomplete"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/utilitydelta/human-replay-vscode-extension"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "humanReplay.startReplay",
        "title": "Start Replay",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.toggle",
        "title": "Toggle Autocomplete",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.comments.add",
        "title": "Human Replay: Add Replay Note"
      },
      {
        "command": "humanReplay.comments.pullPrompt",
        "title": "Comments: Pull into Sandbox Prompt",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.comments.clear",
        "title": "Comments: Clear All",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.comments.nextBlock",
        "title": "Comments: Keep for Next Block",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.cancelDisclosure",
        "title": "Cancel Replay",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.runNextStep",
        "title": "Run Next Step",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.startOllama",
        "title": "Start Ollama (ollama serve in a terminal)",
        "category": "Human Replay"
      },
      {
        "command": "humanReplay.guide.runStepAt",
        "title": "Run This Step",
        "icon": "$(play)"
      },
      {
        "command": "humanReplay.guide.skipStepAt",
        "title": "Skip This Step",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "humanReplay.continueDisclosure",
        "title": "Continue Replay (after editing)",
        "category": "Human Replay"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "humanReplay.guideSteps",
          "name": "Replay Guide",
          "when": "humanReplay.guideLoaded"
        }
      ]
    },
    "keybindings": [
      {
        "command": "humanReplay.diffReplayAcceptDecoration",
        "key": "tab",
        "when": "editorTextFocus && humanReplay.diffDecorationActive && !suggestWidgetVisible && !inlineSuggestionVisible"
      },
      {
        "command": "humanReplay.acceptRewriteClear",
        "key": "tab",
        "when": "editorTextFocus && humanReplay.rewriteStrikeActive && !suggestWidgetVisible && !inlineSuggestionVisible"
      },
      {
        "command": "humanReplay.continueDisclosure",
        "key": "tab",
        "when": "editorTextFocus && humanReplay.disclosureDiverged && humanReplay.recoveryEligible && !suggestWidgetVisible && !inlineSuggestionVisible"
      },
      {
        "command": "humanReplay.nudgeGhost",
        "key": "tab",
        "when": "editorTextFocus && humanReplay.disclosureActive && !humanReplay.disclosureDiverged && !suggestWidgetVisible && !inlineSuggestionVisible"
      },
      {
        "command": "humanReplay.diffReplayNudge",
        "key": "tab",
        "when": "editorTextFocus && humanReplay.diffReplayActive && !humanReplay.diffDecorationActive && !suggestWidgetVisible && !inlineSuggestionVisible"
      },
      {
        "command": "humanReplay.cancelDisclosure",
        "key": "escape",
        "when": "editorTextFocus && (humanReplay.disclosureActive || humanReplay.diffDecorationActive || humanReplay.rewriteStrikeActive) && !inlineSuggestionVisible && !suggestWidgetVisible"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "humanReplay.comments.add",
          "when": "false"
        },
        {
          "command": "humanReplay.guide.runStepAt",
          "when": "false"
        },
        {
          "command": "humanReplay.guide.skipStepAt",
          "when": "false"
        },
        {
          "command": "humanReplay.continueDisclosure",
          "when": "false"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "humanReplay.comments.add",
          "group": "inline",
          "when": "commentController == humanReplay.comments"
        }
      ],
      "view/item/context": [
        {
          "command": "humanReplay.guide.runStepAt",
          "when": "view == humanReplay.guideSteps && viewItem == guideStep",
          "group": "inline@1"
        },
        {
          "command": "humanReplay.guide.skipStepAt",
          "when": "view == humanReplay.guideSteps && viewItem == guideStep",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "Human Replay",
      "properties": {
        "humanReplay.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline autocomplete suggestions."
        },
        "humanReplay.apiBase": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Base URL of the local Ollama server."
        },
        "humanReplay.model": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b-base",
          "description": "Ollama model tag. Use a FIM-capable BASE model (not -instruct). e.g. qwen2.5-coder:1.5b-base, codestral:latest."
        },
        "humanReplay.promptModel": {
          "type": "string",
          "default": "qwen2.5-coder:7b-instruct",
          "description": "INSTRUCT model used to turn collated replay comments into a sandbox-agent prompt (the surfacing layer). Must be an -instruct model, not the FIM base model."
        },
        "humanReplay.template": {
          "type": "string",
          "enum": [
            "auto",
            "qwen",
            "codestral",
            "deepseek",
            "starcoder"
          ],
          "default": "auto",
          "description": "FIM prompt template. 'auto' infers from the model name."
        },
        "humanReplay.maxTokens": {
          "type": "number",
          "default": 256,
          "description": "Maximum tokens to generate per completion (num_predict)."
        },
        "humanReplay.temperature": {
          "type": "number",
          "default": 0.01,
          "description": "Sampling temperature. Low values give stable, deterministic completions."
        },
        "humanReplay.debounceMs": {
          "type": "number",
          "default": 300,
          "description": "Delay after the last keystroke before requesting a completion."
        },
        "humanReplay.prefixChars": {
          "type": "number",
          "default": 3000,
          "description": "Characters of context kept before the cursor."
        },
        "humanReplay.suffixChars": {
          "type": "number",
          "default": 1000,
          "description": "Characters of context kept after the cursor."
        },
        "humanReplay.multiline": {
          "type": "boolean",
          "default": true,
          "description": "Allow multi-line completions. Disable for single-line-only suggestions."
        },
        "humanReplay.guidePath": {
          "type": "string",
          "default": "",
          "description": "Path or glob to a replay guide (.md). Empty scans the workspace's replay-guides/ folder."
        },
        "humanReplay.sandboxRoot": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the sandbox tree the guide replays from (the 'after' state). A lean guide carries no code fences; the runner resolves each step's After bytes from <sandboxRoot>/<step file> by symbol. Before bytes come from the open workspace file."
        },
        "humanReplay.sandboxParent": {
          "type": "string",
          "default": "",
          "description": "Folder containing agent sandboxes, offered by Start Replay. Empty defaults to ~/sandbox."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "package": "vsce package",
    "postinstall": "node scripts/fix-grammar-peers.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.21.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@tree-sitter-grammars/tree-sitter-markdown": "^0.3.2",
    "tree-sitter": "^0.22.4",
    "tree-sitter-c-sharp": "^0.21.3",
    "tree-sitter-css": "^0.23.2",
    "tree-sitter-html": "^0.23.2",
    "tree-sitter-python": "^0.21.0",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-typescript": "^0.21.2"
  }
}
